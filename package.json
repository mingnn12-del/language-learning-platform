{
  "name": "language-learning-platform",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch api/index.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "start": "npm run build && node dist/api/index.js",
    "clean": "rimraf dist node_modules package-lock.json",
    "clean:dist": "rimraf dist",
    "clean:cache": "rimraf node_modules/.vite",
    "reinstall": "npm run clean && npm install",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"api/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"api/**/*.ts\"",
    "check": "npm run typecheck && npm run lint && npm run format:check"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.10.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.24",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.3.0",
    "tsx": "^3.12.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.0"
  }
}
